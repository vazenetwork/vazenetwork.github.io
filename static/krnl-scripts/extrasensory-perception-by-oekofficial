-- ================= HUD =================
local function newText(color)
    local t = Drawing.new("Text")
    t.Size = 18
    t.Center = true
    t.Outline = true
    t.Color = color
    return t
end

local topSpeedText = newText(Color3.fromRGB(0, 255, 255))
local topDirText = newText(Color3.fromRGB(255, 255, 255))
local topAltAGL = newText(Color3.fromRGB(255, 150, 0))

local topGuiPos = Vector2.new(Camera.ViewportSize.X / 2, 20)

topSpeedText.Position = topGuiPos
topDirText.Position = topGuiPos + Vector2.new(0, 20)
topAltAGL.Position = topGuiPos + Vector2.new(0, 40)

-- ================= DRAG =================
local dragging = false
local dragOffset = Vector2.zero

UserInputService.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        local mouse = UserInputService:GetMouseLocation()

        if (mouse - topSpeedText.Position).Magnitude < 120 then
            dragging = true
            dragOffset = mouse - topGuiPos
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        topGuiPos = UserInputService:GetMouseLocation() - dragOffset

        topSpeedText.Position = topGuiPos
        topDirText.Position = topGuiPos + Vector2.new(0, 20)
        topAltAGL.Position = topGuiPos + Vector2.new(0, 40)
    end
end)

-- ================= HELPERS =================
local function degreesToDirection(deg)
    local dirs = {"N","NE","E","SE","S","SW","W","NW"}
    return dirs[math.floor((deg/45)+0.5)%8+1]
end

local function getDirectionFromLook(vec)
    local a = math.deg(math.atan2(vec.X, vec.Z))
    if a < 0 then a += 360 end
    return degreesToDirection(a), math.floor(a)
end

local function getHealthColor(p)
    if p > 0.6 then return Color3.fromRGB(0,255,0)
    elseif p > 0.3 then return Color3.fromRGB(255,255,0)
    else return Color3.fromRGB(255,0,0) end
end

-- ================= FIXED AGL =================
local function getAltitudeAGL(pos)
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist

    local ignore = {}

    for _,p in ipairs(Players:GetPlayers()) do
        if p.Character then
            table.insert(ignore, p.Character)
        end
    end

    params.FilterDescendantsInstances = ignore
    params.IgnoreWater = false

    local result = Workspace:Raycast(pos, Vector3.new(0, -5000, 0), params)

    if result then
        return math.floor((pos - result.Position).Magnitude)
    end

    return math.floor(pos.Y)
end

-- visibility check
local function isInViewAndFront(pos)
    local camCF = Camera.CFrame
    local dir = (pos - camCF.Position).Unit
    if camCF.LookVector:Dot(dir) <= 0 then
        return false
    end
    local _, onScreen = Camera:WorldToViewportPoint(pos)
    return onScreen
end

local function getScreenBounds(a, b)
    local tl = Vector2.new(math.min(a.X,b.X), math.min(a.Y,b.Y))
    local s = Vector2.new(math.abs(a.X-b.X), math.abs(a.Y-b.Y))
    return tl, s
end

-- ================= CLEANUP =================
local function setup(p)
    p.CharacterAdded:Connect(function()
        drawings[p] = nil
    end)
end

for _,p in ipairs(Players:GetPlayers()) do
    if p ~= LocalPlayer then setup(p) end
end

Players.PlayerAdded:Connect(function(p)
    if p ~= LocalPlayer then setup(p) end
end)

